<script>
/* ====================================================================
   JS · animações + interações
   ==================================================================== */

// Reveal on scroll
const obs = new IntersectionObserver((es)=>{
  es.forEach(e=>{ if(e.isIntersecting) e.target.classList.add('visible') })
},{threshold:.15});
document.querySelectorAll('.reveal').forEach(el=>obs.observe(el));

// Counter
const counters = new IntersectionObserver((es)=>{
  es.forEach(e=>{
    if(!e.isIntersecting) return;
    const el = e.target;
    const target = parseInt(el.dataset.counter,10);
    const dur = 1300; const start = performance.now();
    const tick = (now)=>{
      const t = Math.min((now-start)/dur,1);
      const ease = 1-Math.pow(1-t,3);
      el.textContent = Math.round(target*ease);
      if(t<1) requestAnimationFrame(tick);
    };
    requestAnimationFrame(tick);
    counters.unobserve(el);
  });
},{threshold:.4});
document.querySelectorAll('[data-counter]').forEach(el=>counters.observe(el));

// Bars animadas
const barObs = new IntersectionObserver((es)=>{
  es.forEach(e=>{
    if(e.isIntersecting){
      e.target.style.height = e.target.dataset.h + '%';
      barObs.unobserve(e.target);
    }
  });
},{threshold:.3});
document.querySelectorAll('.proj-bar').forEach(b=>barObs.observe(b));

// Roadmap line
const roadObs = new IntersectionObserver((es)=>{
  es.forEach(e=>{
    if(e.isIntersecting){
      const fill = document.getElementById('road-fill');
      if(fill) fill.style.width = '90%';
      roadObs.unobserve(e.target);
    }
  });
},{threshold:.5});
const r = document.querySelector('.roadmap');
if(r) roadObs.observe(r);

// Progress + side dex
const sections = document.querySelectorAll('.slide');
const dots = document.querySelectorAll('.sidedex-dot');
const progress = document.getElementById('progress');
function onScroll(){
  const sc = window.scrollY;
  const max = document.body.scrollHeight - window.innerHeight;
  progress.style.width = ((sc/max)*100) + '%';
  let active = 0;
  sections.forEach((s,i)=>{ if(s.offsetTop - 200 <= sc) active = i; });
  dots.forEach((d,i)=>d.classList.toggle('active',i===active));
}
window.addEventListener('scroll', onScroll, {passive:true});
onScroll();

// Apresentação fullscreen
function enterPresentation(){
  document.documentElement.requestFullscreen?.();
}

// Atalhos de teclado
let currentSlide = 0;
document.addEventListener('keydown', (e)=>{
  if(e.key==='ArrowDown'||e.key==='ArrowRight'||e.key===' '){
    e.preventDefault();
    currentSlide = Math.min(currentSlide+1, sections.length-1);
    sections[currentSlide].scrollIntoView({behavior:'smooth'});
  } else if(e.key==='ArrowUp'||e.key==='ArrowLeft'){
    e.preventDefault();
    currentSlide = Math.max(currentSlide-1, 0);
    sections[currentSlide].scrollIntoView({behavior:'smooth'});
  } else if(e.key==='Escape'){
    if(document.fullscreenElement) document.exitFullscreen();
  } else if(e.key==='Home'){
    currentSlide=0; sections[0].scrollIntoView({behavior:'smooth'});
  } else if(e.key==='End'){
    currentSlide=sections.length-1; sections[currentSlide].scrollIntoView({behavior:'smooth'});
  }
});
let scrollTimer;
window.addEventListener('scroll', ()=>{
  clearTimeout(scrollTimer);
  scrollTimer = setTimeout(()=>{
    const sc = window.scrollY;
    sections.forEach((s,i)=>{ if(s.offsetTop - 200 <= sc) currentSlide = i; });
  }, 100);
});
</script>
</body>
</html>
