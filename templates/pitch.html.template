<!doctype html>
<!-- ====================================================================
     PITCH HTML TEMPLATE · skill proposta-comercial v1.0
     12 slides scroll editorial · placeholders {{}} substituídos pelo builder
     Idioma: {{IDIOMA}} · Cliente: {{NOME_CLIENTE}} · Data: {{DATA_GERACAO}}
     ==================================================================== -->
<html lang="{{IDIOMA}}">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>{{NOME_CLIENTE}} · {{TITULO_PITCH}}</title>
<meta name="description" content="{{DESCRICAO_PITCH}}" />
<meta name="robots" content="noindex,nofollow" />
<meta name="theme-color" content="{{COR_PRIMARY}}" />
<link rel="icon" type="image/svg+xml" href="{{FAVICON_URL}}" />

<!-- Google Fonts -->
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?{{GOOGLE_FONTS_URL}}&display=swap" rel="stylesheet" />

<!-- Style tokens (paleta + tipografia customizada) -->
<link rel="stylesheet" href="style-tokens.css" />

<style>
/* ====================================================================
   CSS DO PITCH · estrutura comum a todos os pitchs gerados pela skill
   Tokens de cor/tipo vêm de style-tokens.css
   ==================================================================== */

*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth;-webkit-text-size-adjust:100%}
body{
  font-family:var(--sans);background:var(--neutral-light);color:var(--text);
  line-height:1.55;-webkit-font-smoothing:antialiased;
  overflow-x:hidden;
}
::selection{background:var(--primary);color:#fff}
img{max-width:100%;display:block;height:auto}
a{color:inherit;text-decoration:none}
button{font-family:inherit;cursor:pointer}
ul{list-style:none}
h1,h2,h3,h4{font-family:var(--serif);font-weight:500;letter-spacing:-0.02em;line-height:1.1;color:var(--text)}
em{font-style:italic;color:var(--primary)}

/* ----- Top bar ----- */
.topbar{
  position:fixed;top:0;left:0;right:0;z-index:var(--z-modal);
  background:rgba(255,255,255,.94);backdrop-filter:saturate(150%) blur(10px);
  border-bottom:1px solid var(--border);
  padding:12px 28px;display:flex;align-items:center;justify-content:space-between;
  font-size:12px;font-weight:500;
}
.topbar-brand{
  display:flex;align-items:center;gap:10px;color:var(--primary);
  font-weight:600;letter-spacing:.06em;text-transform:uppercase;font-size:11px;
}
.topbar-brand::before{content:"●";color:var(--accent)}
.topbar-progress{flex:1;height:2px;background:var(--border);margin:0 32px;border-radius:1px;overflow:hidden;max-width:400px}
.topbar-progress-bar{height:100%;background:linear-gradient(90deg,var(--primary),var(--accent));width:0;transition:width .3s ease}
.topbar-actions{display:flex;gap:8px;align-items:center}
.topbar-btn{
  padding:8px 14px;background:transparent;border:1px solid var(--border);border-radius:999px;
  font-size:11px;letter-spacing:.08em;text-transform:uppercase;color:var(--text);font-weight:500;
  transition:all .2s;display:flex;align-items:center;gap:6px;font-family:inherit;
}
.topbar-btn:hover{background:var(--text);color:#fff;border-color:var(--text)}
.topbar-btn.primary{background:var(--primary);color:#fff;border-color:var(--primary)}
.topbar-btn.primary:hover{background:var(--primary-deep)}
@media (max-width:768px){.topbar-progress{display:none}.topbar{padding:10px 16px}}

/* ----- Side index ----- */
.sidedex{
  position:fixed;left:24px;top:50%;transform:translateY(-50%);z-index:var(--z-nav);
  display:flex;flex-direction:column;gap:10px;
}
.sidedex-dot{
  width:8px;height:8px;border-radius:50%;background:var(--border);
  transition:all .3s;cursor:pointer;position:relative;
}
.sidedex-dot.active{background:var(--primary);transform:scale(1.4)}
.sidedex-dot::after{
  content:attr(data-label);position:absolute;left:18px;top:50%;transform:translateY(-50%);
  font-size:10px;letter-spacing:.18em;text-transform:uppercase;color:var(--primary);
  white-space:nowrap;opacity:0;transition:opacity .2s;pointer-events:none;font-weight:600;
}
.sidedex-dot:hover::after,.sidedex-dot.active::after{opacity:1}
@media (max-width:1024px){.sidedex{display:none}}

/* ----- Slide base ----- */
.slide{
  min-height:100vh;
  padding:120px var(--pad) 80px;
  position:relative;z-index:var(--z-content);
  display:flex;flex-direction:column;justify-content:center;
}
@media (max-width:768px){.slide{padding:90px var(--pad) 60px}}
.container{max-width:var(--container);margin:0 auto;width:100%}
.slide-num{
  font-family:var(--mono);
  font-size:11px;letter-spacing:.2em;color:var(--text-mute);
  margin-bottom:32px;display:flex;align-items:center;gap:14px;
}
.slide-num::after{content:"";flex:1;height:1px;background:var(--border);max-width:120px}
.eyebrow{
  display:inline-flex;align-items:center;gap:10px;
  font-size:11px;letter-spacing:.4em;text-transform:uppercase;color:var(--primary);
  font-weight:600;margin-bottom:18px;
}
.eyebrow::before{content:"";width:36px;height:1px;background:var(--accent)}
.slide-title{
  font-family:var(--serif);font-weight:400;
  font-size:clamp(46px,6vw,82px);
  line-height:1.05;letter-spacing:-.01em;
  margin-bottom:28px;color:var(--text);
}
.slide-title em{color:var(--primary);font-style:italic}
.slide-lede{
  font-size:20px;line-height:1.55;color:var(--text-soft);
  max-width:760px;margin-bottom:48px;
}

/* ===========================================================
   SLIDE 01 · COVER
   =========================================================== */
.cover{
  background:linear-gradient(135deg,var(--primary-deep) 0%,var(--primary) 60%,#020817 100%);
  color:#fff;min-height:100vh;
  padding:140px var(--pad) 80px;overflow:hidden;position:relative;
}
.cover-orb{position:absolute;border-radius:50%;filter:blur(80px);opacity:.4;pointer-events:none}
.cover-orb.gold{background:var(--accent);width:600px;height:600px;top:-200px;right:-100px}
.cover-orb.blue{background:var(--primary-light);width:400px;height:400px;bottom:-100px;left:10%;opacity:.3}
.cover-grid{
  position:absolute;inset:0;
  background-image:linear-gradient(rgba(255,255,255,.03) 1px,transparent 1px),linear-gradient(90deg,rgba(255,255,255,.03) 1px,transparent 1px);
  background-size:60px 60px;
  mask-image:radial-gradient(ellipse 80% 60% at center,black,transparent);
  pointer-events:none;
}
.cover-content{position:relative;z-index:2;max-width:1100px;margin:auto 0}
.cover-eyebrow{font-family:var(--mono);font-size:12px;letter-spacing:.3em;color:var(--accent-soft);margin-bottom:48px}
.cover-name{
  font-family:var(--serif);font-weight:400;
  font-size:clamp(56px,11vw,140px);
  line-height:.95;letter-spacing:-.02em;color:#fff;margin-bottom:40px;
}
.cover-name em{color:var(--accent-soft);font-style:italic}
.cover-meta{
  display:flex;gap:60px;flex-wrap:wrap;
  border-top:1px solid rgba(255,255,255,.18);
  padding-top:40px;margin-top:60px;max-width:900px;
}
.cover-meta div{font-size:13px;color:rgba(255,255,255,.7);letter-spacing:.06em;line-height:1.5}
.cover-meta strong{
  display:block;font-family:var(--serif);font-size:24px;color:var(--accent-soft);
  font-weight:500;margin-bottom:6px;font-style:italic;
}
.cover-bottom{
  position:absolute;bottom:40px;left:var(--pad);right:var(--pad);
  display:flex;justify-content:space-between;align-items:flex-end;
  font-size:11px;letter-spacing:.2em;color:rgba(255,255,255,.4);text-transform:uppercase;
}
@media (max-width:768px){.cover-bottom{flex-direction:column;gap:8px;align-items:flex-start}}

/* ===========================================================
   SLIDE 02 · ESPELHO DOS NÚMEROS
   =========================================================== */
.mirror-grid{
  display:grid;grid-template-columns:repeat(4,1fr);gap:1px;
  background:var(--border);border:1px solid var(--border);margin-top:40px;
}
@media (max-width:1024px){.mirror-grid{grid-template-columns:repeat(2,1fr)}}
.mirror-cell{background:var(--neutral-light);padding:40px 32px;transition:background .3s}
.mirror-cell:hover{background:var(--neutral-warm)}
.mirror-num{
  font-family:var(--serif);font-size:72px;line-height:.95;
  color:var(--primary);font-weight:500;margin-bottom:14px;letter-spacing:-.02em;
}
.mirror-num em{color:var(--accent-deep);font-style:italic;font-size:48px;vertical-align:super}
.mirror-label{font-size:12px;letter-spacing:.18em;text-transform:uppercase;color:var(--text-soft);font-weight:600;line-height:1.4}
.mirror-tape{
  margin-top:60px;display:flex;gap:14px;flex-wrap:wrap;align-items:center;
  padding:24px 32px;background:var(--neutral-warm);border-radius:var(--radius);border:1px solid var(--border);
}
.mirror-tape strong{font-family:var(--serif);font-style:italic;font-size:24px;color:var(--primary);font-weight:500}
.credentials-marquee{
  margin-top:30px;display:flex;flex-wrap:wrap;gap:8px 16px;
  font-size:13px;color:var(--text-soft);font-weight:500;
}
.credentials-marquee span{padding:6px 14px;background:var(--neutral-warm);border-radius:99px;border:1px solid var(--border)}

/* ===========================================================
   SLIDE 03 · BIO EDITORIAL
   =========================================================== */
.bio-grid{display:grid;grid-template-columns:1.3fr 1fr;gap:80px;align-items:center;margin-top:40px}
@media (max-width:1024px){.bio-grid{grid-template-columns:1fr;gap:48px}}
.bio-quote{
  font-family:var(--serif);font-style:italic;font-weight:400;
  font-size:36px;line-height:1.25;color:var(--primary);
  border-left:2px solid var(--accent);padding-left:28px;margin-bottom:36px;
}
.bio-text p{margin-bottom:18px;font-size:17px;color:var(--text-soft);line-height:1.65}
.bio-text strong{color:var(--text)}
.bio-portrait{
  aspect-ratio:3/4;background:var(--neutral-warm);
  border-radius:var(--radius);overflow:hidden;position:relative;
  box-shadow:var(--shadow-lg);border:1px solid var(--border);
}
.bio-portrait img{width:100%;height:100%;object-fit:cover;object-position:center 20%}
.bio-portrait::after{content:"";position:absolute;inset:14px;border:1px solid rgba(255,255,255,.5);pointer-events:none}
.creds-strip{margin-top:80px;display:grid;grid-template-columns:repeat(5,1fr);gap:14px}
@media (max-width:1024px){.creds-strip{grid-template-columns:repeat(3,1fr)}}
@media (max-width:640px){.creds-strip{grid-template-columns:repeat(2,1fr)}}
.cred-card{background:var(--neutral-warm);border:1px solid var(--border);border-radius:var(--radius);padding:24px 20px;text-align:center}
.cred-year{font-family:var(--mono);font-size:11px;color:var(--accent-deep);letter-spacing:.2em;font-weight:600;margin-bottom:8px}
.cred-inst{font-family:var(--serif);font-size:15px;font-weight:500;color:var(--text);line-height:1.2}

/* ===========================================================
   SLIDE 04 · O QUE PRESERVAR
   =========================================================== */
.preserve-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:24px;margin-top:40px}
@media (max-width:1024px){.preserve-grid{grid-template-columns:repeat(2,1fr)}}
@media (max-width:640px){.preserve-grid{grid-template-columns:1fr}}
.preserve-card{
  background:var(--neutral-warm);padding:36px 28px;border:1px solid var(--border);border-radius:var(--radius);
  transition:all .3s;position:relative;
}
.preserve-card:hover{transform:translateY(-4px);box-shadow:var(--shadow-md)}
.preserve-num{
  position:absolute;top:24px;right:24px;
  font-family:var(--serif);font-style:italic;font-size:42px;color:var(--accent);
  font-weight:400;line-height:1;opacity:.5;
}
.preserve-icon{
  width:48px;height:48px;background:var(--primary);color:var(--accent-soft);
  border-radius:12px;display:flex;align-items:center;justify-content:center;
  font-family:var(--serif);font-size:22px;margin-bottom:24px;font-weight:500;
}
.preserve-title{font-family:var(--serif);font-size:24px;font-weight:500;margin-bottom:10px;color:var(--text);line-height:1.15}
.preserve-text{font-size:14px;color:var(--text-soft);line-height:1.55}

/* ===========================================================
   SLIDE 05 · OPORTUNIDADES (TABELA 4 COLUNAS)
   =========================================================== */
.opp-table{
  width:100%;border-collapse:separate;border-spacing:0;margin-top:40px;
  border:1px solid var(--border);background:var(--neutral-warm);border-radius:var(--radius);overflow:hidden;
}
.opp-table thead{background:var(--primary);color:#fff}
.opp-table th{text-align:left;padding:18px 24px;font-size:11px;letter-spacing:.18em;text-transform:uppercase;font-weight:600;font-family:var(--sans)}
.opp-table td{padding:24px;border-top:1px solid var(--border);vertical-align:top;font-size:15px;color:var(--text)}
.opp-table tr:hover td{background:rgba(201,169,97,.06)}
.opp-icon{
  width:32px;height:32px;border-radius:50%;background:var(--accent);color:var(--primary-deep);
  display:inline-flex;align-items:center;justify-content:center;
  font-family:var(--serif);font-size:16px;font-weight:600;
}
.opp-impact{font-family:var(--serif);font-style:italic;font-size:18px;color:var(--primary);font-weight:500;line-height:1.3}
@media (max-width:768px){
  .opp-table thead{display:none}
  .opp-table tr{display:block;padding:20px;border-top:1px solid var(--border)}
  .opp-table td{display:block;padding:6px 0;border:none;font-size:14px}
}

/* ===========================================================
   SLIDE 06 · DIREÇÃO CRIATIVA (PALETA + TIPOGRAFIA)
   =========================================================== */
.moodboard{display:grid;grid-template-columns:1fr 1fr;gap:40px;margin-top:40px}
@media (max-width:1024px){.moodboard{grid-template-columns:1fr}}
.palette{display:grid;grid-template-columns:repeat(2,1fr);gap:14px}
.swatch{
  aspect-ratio:1.5;border-radius:var(--radius);padding:20px;color:#fff;
  display:flex;flex-direction:column;justify-content:flex-end;
  transition:transform .3s;cursor:pointer;position:relative;overflow:hidden;
  border:1px solid var(--border);
}
.swatch:hover{transform:scale(1.03)}
.swatch-hex{font-family:var(--mono);font-size:11px;letter-spacing:.1em;opacity:.75;margin-bottom:4px}
.swatch-name{font-family:var(--serif);font-style:italic;font-size:22px;font-weight:500}
.typo-stack{background:var(--neutral-warm);padding:36px 32px;border:1px solid var(--border);border-radius:var(--radius)}
.typo-row{padding:18px 0;border-bottom:1px solid var(--border)}
.typo-row:last-child{border:none}
.typo-label{font-size:10px;letter-spacing:.3em;text-transform:uppercase;color:var(--text-mute);margin-bottom:10px;font-weight:600}
.typo-sample-display{font-family:var(--serif);font-style:italic;font-size:42px;line-height:1;color:var(--primary);font-weight:500}
.typo-sample-body{font-family:var(--sans);font-size:18px;color:var(--text-soft);line-height:1.5}
.principles{grid-column:1/-1;margin-top:20px;display:grid;grid-template-columns:repeat(3,1fr);gap:14px}
@media (max-width:768px){.principles{grid-template-columns:1fr}}
.principle{padding:24px 22px;background:var(--neutral-light);border:1px solid var(--border);border-radius:var(--radius)}
.principle-name{font-family:var(--serif);font-style:italic;font-size:18px;color:var(--primary);margin-bottom:8px;font-weight:500}
.principle-desc{font-size:13px;color:var(--text-soft);line-height:1.5}

/* ===========================================================
   SLIDE 07 · MOCKUP / SITE EM IFRAME
   =========================================================== */
.laptop{
  margin:40px auto 0;max-width:1100px;
  border-radius:14px 14px 4px 4px;background:#1a1410;padding:14px 14px 0;
  box-shadow:0 60px 120px -30px rgba(0,0,0,.45);position:relative;
}
.laptop::after{content:"";display:block;height:18px;background:#0a0606;border-radius:0 0 14px 14px;margin:0 -14px}
.laptop-bar{display:flex;gap:6px;padding:8px 4px;align-items:center}
.laptop-bar-dot{width:8px;height:8px;border-radius:50%;background:#3a2d28}
.laptop-bar-url{flex:1;background:#0a0606;color:rgba(255,255,255,.5);padding:4px 14px;border-radius:6px;font-family:var(--mono);font-size:10px;text-align:center}
.laptop-screen{aspect-ratio:16/10;background:var(--neutral-light);overflow:hidden;border-radius:2px;position:relative}
.laptop-screen iframe{width:100%;height:100%;border:none;background:var(--neutral-light)}
.laptop-actions{display:flex;gap:12px;justify-content:center;margin-top:32px;flex-wrap:wrap}

/* ===========================================================
   SLIDE 08 · PRODUTOS (com mocks visuais)
   =========================================================== */
.products{display:grid;grid-template-columns:repeat(2,1fr);gap:32px;margin-top:40px}
@media (max-width:1024px){.products{grid-template-columns:1fr}}
.product-card{
  background:var(--neutral-warm);border:1px solid var(--border);border-radius:var(--radius);
  overflow:hidden;display:flex;flex-direction:column;transition:all .3s;
}
.product-card:hover{transform:translateY(-4px);box-shadow:var(--shadow-md)}
.product-mock{aspect-ratio:16/10;display:flex;align-items:center;justify-content:center;position:relative;overflow:hidden}
.product-body{padding:32px}
.product-tag{
  display:inline-block;font-size:10px;letter-spacing:.2em;text-transform:uppercase;
  color:#fff;background:var(--primary);padding:5px 10px;border-radius:4px;
  margin-bottom:16px;font-weight:600;
}
.product-name{font-family:var(--serif);font-size:28px;font-weight:500;margin-bottom:10px;color:var(--text);line-height:1.15}
.product-pitch{font-size:14px;color:var(--text-soft);line-height:1.55;margin-bottom:18px}
.product-meta{display:flex;gap:20px;flex-wrap:wrap;font-size:11px;letter-spacing:.12em;text-transform:uppercase;color:var(--text-mute);font-weight:600}
.product-meta strong{color:var(--primary)}

/* ===========================================================
   MOCKS VISUAIS · 8 tipos disponíveis
   Importados de library/mock-snippets.html
   ===========================================================
   Mock styles devem ser inline · cada produto especifica qual
   mock usar (ex: class="product-mock mock-app")

   Os 8 mocks estão no library/mock-snippets.html
   Builder copia o CSS de cada mock pra cá durante a build
   =========================================================== */

{{MOCK_STYLES_INSERT_HERE}}

/* ===========================================================
   SLIDE 09 · PROJEÇÃO FINANCEIRA
   =========================================================== */
.proj{margin-top:40px}
.proj-table{width:100%;border-collapse:separate;border-spacing:0;background:var(--neutral-warm);border:1px solid var(--border);border-radius:var(--radius);overflow:hidden}
.proj-table th{background:var(--primary-deep);color:#fff;padding:18px 24px;text-align:left;font-size:11px;letter-spacing:.18em;text-transform:uppercase;font-weight:600;font-family:var(--sans)}
.proj-table th:nth-child(2),.proj-table th:nth-child(3),.proj-table td:nth-child(2),.proj-table td:nth-child(3){text-align:right}
.proj-table td{padding:18px 24px;border-top:1px solid var(--border);font-size:15px}
.proj-table tfoot td{font-family:var(--serif);font-style:italic;font-size:24px;color:var(--primary);font-weight:500;background:rgba(201,169,97,.1)}
.proj-bars{margin-top:40px;display:grid;grid-template-columns:repeat(6,1fr);gap:12px;align-items:end;height:240px}
.proj-bar-wrap{display:flex;flex-direction:column;align-items:center;height:100%;justify-content:flex-end}
.proj-bar{width:100%;background:linear-gradient(180deg,var(--accent),var(--primary));border-radius:4px 4px 0 0;transition:height 1.2s var(--ease);position:relative}
.proj-bar.bonus{background:linear-gradient(180deg,var(--accent-soft),var(--accent));box-shadow:0 0 24px rgba(201,169,97,.4);outline:2px dashed var(--accent);outline-offset:3px}
.proj-bar-val{position:absolute;top:-22px;left:50%;transform:translateX(-50%);font-family:var(--mono);font-size:10px;color:var(--primary);font-weight:600;white-space:nowrap}
.proj-bar-label{margin-top:10px;font-size:10px;letter-spacing:.1em;text-transform:uppercase;color:var(--text-soft);text-align:center;font-weight:600;line-height:1.3}
.proj-disclaimer{margin-top:32px;font-size:12px;color:var(--text-mute);font-style:italic}
.proj-bonus-card{
  margin-top:48px;padding:28px 32px;
  background:linear-gradient(135deg,rgba(201,169,97,.1),rgba(0,81,123,.05));
  border:1px solid var(--accent);border-radius:var(--radius);
}
.proj-bonus-tag{font-family:var(--mono);font-size:11px;letter-spacing:.2em;color:var(--accent-deep);text-transform:uppercase;margin-bottom:10px;font-weight:700}
.proj-bonus-title{font-family:var(--serif);font-style:italic;font-size:24px;color:var(--primary);line-height:1.3;margin-bottom:8px}
.proj-bonus-desc{font-size:14px;color:var(--text-soft);line-height:1.55}

/* ===========================================================
   SLIDE 10 · MODELOS DE PARCERIA (3 cards)
   =========================================================== */
.partnership{display:grid;grid-template-columns:repeat(3,1fr);gap:24px;margin-top:40px}
@media (max-width:1024px){.partnership{grid-template-columns:1fr}}
.partner-card{
  background:var(--neutral-warm);border:1px solid var(--border);border-radius:var(--radius);
  padding:36px 28px;position:relative;display:flex;flex-direction:column;transition:all .3s;
}
.partner-card.recommended{
  background:var(--primary-deep);color:#fff;border-color:var(--accent);
  transform:scale(1.02);box-shadow:var(--shadow-lg);
}
.partner-card.recommended .partner-letter{color:var(--accent)}
.partner-card.recommended .partner-title{color:#fff}
.partner-card.recommended .partner-desc,.partner-card.recommended .partner-bullets li{color:rgba(255,255,255,.78)}
.partner-card.recommended .partner-fit{border-top-color:rgba(255,255,255,.2);color:var(--accent-soft)}
.partner-badge{
  position:absolute;top:-14px;left:50%;transform:translateX(-50%);
  background:var(--accent);color:var(--primary-deep);
  padding:6px 18px;border-radius:99px;font-size:10px;letter-spacing:.2em;text-transform:uppercase;font-weight:700;
}
.partner-letter{font-family:var(--serif);font-style:italic;font-size:72px;color:var(--accent-deep);font-weight:400;line-height:.85;margin-bottom:8px}
.partner-name{font-size:11px;letter-spacing:.3em;text-transform:uppercase;color:var(--text-mute);font-weight:600;margin-bottom:18px}
.partner-card.recommended .partner-name{color:rgba(255,255,255,.55)}
.partner-title{font-family:var(--serif);font-size:26px;font-weight:500;color:var(--text);margin-bottom:14px;line-height:1.15}
.partner-desc{font-size:14px;color:var(--text-soft);line-height:1.55;margin-bottom:20px}
.partner-bullets{margin-bottom:24px}
.partner-bullets li{font-size:13px;color:var(--text-soft);padding:6px 0 6px 22px;position:relative}
.partner-bullets li::before{content:"•";position:absolute;left:8px;color:var(--accent);font-weight:700;font-size:18px;line-height:1}
.partner-fit{margin-top:auto;padding-top:18px;border-top:1px solid var(--border);font-family:var(--serif);font-style:italic;font-size:15px;color:var(--primary)}

/* ===========================================================
   SLIDE 11 · ROADMAP
   =========================================================== */
.roadmap{margin-top:40px;position:relative}
.roadmap-line{position:absolute;top:48px;left:5%;right:5%;height:2px;background:var(--border)}
.roadmap-line-fill{position:absolute;top:48px;left:5%;height:2px;background:linear-gradient(90deg,var(--primary),var(--accent));width:0;transition:width 1.5s ease}
.roadmap-grid{display:grid;grid-template-columns:repeat(6,1fr);gap:20px;position:relative;z-index:1}
@media (max-width:1024px){.roadmap-grid{grid-template-columns:repeat(2,1fr);gap:30px}.roadmap-line,.roadmap-line-fill{display:none}}
.road-step{text-align:center;display:flex;flex-direction:column;align-items:center}
.road-dot{
  width:48px;height:48px;border-radius:50%;background:var(--neutral-light);
  border:2px solid var(--primary);color:var(--primary);
  display:flex;align-items:center;justify-content:center;
  font-family:var(--serif);font-style:italic;font-size:22px;font-weight:600;
  margin-bottom:18px;position:relative;z-index:2;
}
.road-week{font-size:10px;letter-spacing:.18em;text-transform:uppercase;color:var(--primary);font-weight:600;margin-bottom:8px}
.road-title{font-family:var(--serif);font-size:18px;font-weight:600;color:var(--text);margin-bottom:8px;line-height:1.2}
.road-desc{font-size:12px;color:var(--text-soft);line-height:1.45}

/* ===========================================================
   SLIDE 12 · CTA FINAL
   =========================================================== */
.final{
  background:linear-gradient(135deg,var(--primary-deep),#020817);
  color:#fff;min-height:100vh;
  display:flex;flex-direction:column;justify-content:center;align-items:center;text-align:center;
  padding:120px var(--pad);position:relative;overflow:hidden;
}
.final-orb{position:absolute;border-radius:50%;filter:blur(120px);opacity:.4;pointer-events:none}
.final-orb.gold{background:var(--accent);width:600px;height:600px;top:-200px;left:50%;transform:translateX(-50%)}
.final-content{position:relative;z-index:2;max-width:800px}
.final-pre{font-family:var(--mono);font-size:12px;letter-spacing:.3em;color:var(--accent-soft);margin-bottom:32px}
.final-title{font-family:var(--serif);font-style:italic;font-size:clamp(48px,7vw,84px);line-height:1.05;color:#fff;margin-bottom:32px;font-weight:500}
.final-title em{color:var(--accent-soft)}
.final-lede{font-size:22px;color:rgba(255,255,255,.85);line-height:1.55;margin-bottom:48px}
.final-cta{display:flex;gap:16px;justify-content:center;flex-wrap:wrap;margin-bottom:60px}
.btn{
  padding:20px 40px;border-radius:999px;font-size:13px;font-weight:600;
  letter-spacing:.12em;text-transform:uppercase;transition:all .3s;
  border:1px solid;display:inline-block;font-family:inherit;
}
.btn-gold{background:var(--accent);color:var(--primary-deep);border-color:var(--accent)}
.btn-gold:hover{background:var(--accent-soft);transform:translateY(-2px);box-shadow:0 14px 40px -10px rgba(201,169,97,.5)}
.btn-outline{border-color:rgba(255,255,255,.4);color:#fff;background:transparent}
.btn-outline:hover{background:#fff;color:var(--primary-deep);border-color:#fff}
.final-sig{
  border-top:1px solid rgba(255,255,255,.18);padding-top:32px;margin-top:32px;
  display:flex;justify-content:space-between;flex-wrap:wrap;gap:14px;
  font-family:var(--mono);font-size:11px;letter-spacing:.2em;color:rgba(255,255,255,.55);text-transform:uppercase;
}

/* ----- Reveal animations ----- */
.reveal{opacity:0;transform:translateY(30px);transition:opacity 1s var(--ease),transform 1s var(--ease)}
.reveal.visible{opacity:1;transform:translateY(0)}
.stagger-1{transition-delay:.1s}.stagger-2{transition-delay:.2s}.stagger-3{transition-delay:.3s}.stagger-4{transition-delay:.4s}

[data-counter]{display:inline-block}

/* ----- Print ----- */
@media print{
  .topbar,.sidedex{display:none}
  .slide{break-after:page;min-height:auto}
  body{background:white;color:black}
}
</style>
</head>
